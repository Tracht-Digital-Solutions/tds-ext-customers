{
  "name": "tracht-digital-solutions/tds-ext-customers",
  "description": "Customer/company directory for the TDS panel (backend Module).",
  "type": "library",
  "license": "proprietary",
  "version": "0.1.4",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.13",
    "tracht-digital-solutions/tds-frontend-contract": "^1.0.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/Tracht-Digital-Solutions/tds-frontend-contract-pkg"
    }
  ],
  "autoload": {
    "psr-4": {
      "Tds\\Ext\\Customers\\": "php/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tds\\Ext\\Customers\\Tests\\": "php/tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist"
  },
  "scripts": {
    "test": "phpunit"
  }
}
